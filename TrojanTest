#!/bin/bash
set -e

# --- HELPER FUNCTIONS ---
banner() { echo -e "\n\033[1;34m$1\033[0m"; }
ok() { echo -e "\033[1;32mвң… $1\033[0m"; }
kv() { echo -e "\033[1;33m$1\033[0m $2"; }

# --- DISPLAY BANNER ---
cat << "EOF"
################################################################################
#
#        в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв•—
#        в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв•‘
#        в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв•”в–Ҳв–Ҳв•— в–Ҳв–Ҳв•‘
#        в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•қ  в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘
#        в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘ в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв•‘
#        в•ҡв•җв•қ  в•ҡв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қв•ҡв•җв•җв•җв•җв•җв•җв•қв•ҡв•җв•қ  в•ҡв•җв•җв•җв•қ
#
#   DEVELOPER: RAEN | PROJECT: Automated Cloud Run Proxy | VERSION: 1.5
#
################################################################################
EOF

# --- Step 1: Protocol Selection ---
banner "рҹҢҗ Step 1 вҖ” Select Protocol"
echo "1) Trojan (WS)"
echo "2) Vless (WS)"
read -p "Selection [1-2, default 1]: " PROTO_INPUT </dev/tty
PROTO_INPUT=${PROTO_INPUT:-1}

# --- Step 2: Resources (CPU & Memory) ---
banner "рҹ§® Step 2 вҖ” Resources"
read -rp "CPU [1/2/4, default 1]: " _cpu </dev/tty
CPU="${_cpu:-1}"

read -rp "Memory [512Mi/1Gi/2Gi/4Gi, default 2Gi]: " _mem </dev/tty
MEMORY="${_mem:-2Gi}"

# SAFETY CHECK: Cloud Run requires at least 2Gi for 2+ CPUs when using --no-cpu-throttling
if [[ "$CPU" -ge 2 ]] && [[ "$MEMORY" == "1Gi" || "$MEMORY" == "512Mi" ]]; then
    echo -e "\033[1;31mвҡ пёҸ  Note: $CPU vCPU requires at least 2Gi Memory. Auto-adjusting to 2Gi...\033[0m"
    MEMORY="2Gi"
fi
ok "Resources: ${CPU} vCPU / ${MEMORY}"

# --- Step 3: Service Name ---
banner "рҹӘӘ Step 3 вҖ” Service Name"
DEFAULT_SVC="stsnoload"
read -rp "Service name [default: ${DEFAULT_SVC}]: " _svc </dev/tty
SERVICE_NAME="${_svc:-$DEFAULT_SVC}"
SERVICE_NAME=$(echo "$SERVICE_NAME" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9-]//g')
ok "Service: ${SERVICE_NAME}"

# --- Step 4: Timezone Setup (Manila) ---
export TZ="Asia/Manila"
START_EPOCH="$(date +%s)"
# Estimate 5 hours for session/expiry display
END_EPOCH="$(( START_EPOCH + 5*3600 ))"

# Formatting dates for Manila
START_LOCAL="$(date -d @"$START_EPOCH" "+%d.%m.%Y %I:%M %p")"
END_LOCAL="$(date -d @"$END_EPOCH" "+%d.%m.%Y %I:%M %p")"

banner "рҹ•’ Step 4 вҖ” Deployment Time (Manila)"
kv "Current Time:" "${START_LOCAL}"
kv "Session End:"  "${END_LOCAL}"

# --- Step 5: Cloud Configuration ---
REGION="us-central1"
PROJECT_ID=$(gcloud config get-value project)
PROJECT_NUM=$(gcloud projects describe "$PROJECT_ID" --format='value(projectNumber)')
HOST="${SERVICE_NAME}-${PROJECT_NUM}.${REGION}.run.app"

if [ "$PROTO_INPUT" == "2" ]; then
    IMAGE="docker.io/n4pro/vl:latest"
    VLESS_UUID="0c890000-4733-b20e-067f-fc341bd20000"
    URI="vless://${VLESS_UUID}@vpn.googleapis.com:443?path=%2FN4&security=tls&encryption=none&host=${HOST}&type=ws&sni=${HOST}#${SERVICE_NAME}-VLESS"
    DISPLAY_NAME="VLESS-WS"
else
    IMAGE="docker.io/n4pro/tr:latest"
    URI="trojan://Trojan-2025@vpn.googleapis.com:443?path=%2FN4&security=tls&type=ws&sni=${HOST}&host=${HOST}#${SERVICE_NAME}-Trojan"
    DISPLAY_NAME="Trojan-WS"
fi

# --- Step 6: Deploy to Cloud Run ---
banner "вҡҷпёҸ Step 5 вҖ” Deploying $DISPLAY_NAME"
gcloud services enable run.googleapis.com --quiet > /dev/null 2>&1

gcloud run deploy "$SERVICE_NAME" \
    --image="$IMAGE" \
    --platform=managed \
    --region="$REGION" \
    --cpu="$CPU" \
    --memory="$MEMORY" \
    --no-cpu-throttling \
    --allow-unauthenticated \
    --port=8080 \
    --min-instances=1 \
    --quiet

# --- Step 7: Final Output ---
echo -e "\n================================================"
ok "$DISPLAY_NAME DEPLOYMENT SUCCESSFUL"
echo "================================================"
echo "рҹ”— IMPORT LINK:"
echo "$URI"
echo "================================================"
